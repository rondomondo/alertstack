                    "datasource": { "type": "prometheus", "uid": "${datasource}" },
                    "expr": "envoy_cluster_upstream_rq_total",
                    "legendFormat": "{{cluster_name}} / {{envoy_response_code_class}}",
                    "refId": "A"
                }
            ]
        },

        {
            "collapsed": false,
            "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
